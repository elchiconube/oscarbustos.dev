<div id='custom-cursor' aria-hidden='true'></div>
<click-spark aria-hidden='true'></click-spark>

<style>
  :root[data-theme='light'] {
    --cursor-color: #000000;
    --click-spark-color: #000000;
  }

  :root[data-theme='dark'] {
    --cursor-color: #ffffff;
    --click-spark-color: #ffffff;
  }

  /* Solo ratón/trackpad: ocultar cursor del sistema y mostrar el punto tras el primer movimiento */
  @media (pointer: fine) {
    * {
      cursor: none !important;
    }

    #custom-cursor {
      width: 8px;
      height: 8px;
      background-color: var(--cursor-color);
      border-radius: 50%;
      position: fixed;
      left: 0;
      top: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0;
      transition:
        opacity 0.15s ease,
        background-color 0.3s ease;
      will-change: transform;
    }

    #custom-cursor.is-ready {
      opacity: 1;
    }

    click-spark {
      display: block;
    }
  }

  /* Táctil: sin cursor falso en la esquina ni cursor oculto */
  @media (pointer: coarse) {
    #custom-cursor,
    click-spark {
      display: none !important;
    }
  }
</style>

<script>
  class ClickSpark extends HTMLElement {
    constructor() {
      super();
      this.attachShadow({ mode: 'open' });
      this.svg = null;
    }

    connectedCallback() {
      const sr = this.shadowRoot;
      if (!sr) return;
      sr.innerHTML = this.createSpark();
      this.svg = sr.querySelector('svg');
      document.addEventListener('click', this);
    }

    disconnectedCallback() {
      document.removeEventListener('click', this);
    }

    handleEvent(e) {
      if (!(e instanceof MouseEvent)) return;
      this.setSparkPosition(e);
      this.animateSpark();
    }

    animateSpark() {
      if (!this.svg) return;
      const sparks = [...this.svg.children];
      const first = sparks[0];
      if (!first) return;
      const size = parseInt(first.getAttribute('y1') ?? '0', 10);
      const offset = size / 2 + 'px';
      const keyframes = (i) => {
        const deg = `calc(${i} * (360deg / ${sparks.length}))`;
        return [
          {
            strokeDashoffset: size * 3,
            transform: `rotate(${deg}) translateY(${offset})`,
          },
          {
            strokeDashoffset: size,
            transform: `rotate(${deg}) translateY(0)`,
          },
        ];
      };
      const options = {
        duration: 660,
        easing: 'cubic-bezier(0.25, 1, 0.5, 1)',
        fill: 'forwards',
      };
      sparks.forEach((spark, i) => spark.animate(keyframes(i), options));
    }

    setSparkPosition(e) {
      this.style.left = e.pageX - this.clientWidth / 2 + 'px';
      this.style.top = e.pageY - this.clientHeight / 2 + 'px';
    }

    createSpark() {
      return `
        <style>
          :host {
            position: absolute;
            pointer-events: none;
            z-index: 9998;
          }
        </style>
        <svg width="30" height="30" viewBox="0 0 100 100" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" stroke="var(--click-spark-color, currentcolor)" transform="rotate(-20)">
          ${Array.from(
            { length: 8 },
            () =>
              '<line x1="50" y1="30" x2="50" y2="4" stroke-dasharray="30" stroke-dashoffset="30" style="transform-origin: center" />'
          ).join('')}
        </svg>
      `;
    }
  }

  if (!customElements.get('click-spark')) {
    customElements.define('click-spark', ClickSpark);
  }

  function setupCustomCursor() {
    if (!window.matchMedia('(pointer: fine)').matches) return;

    const cursor = document.querySelector('#custom-cursor');
    if (!(cursor instanceof HTMLElement)) return;

    const move = (e) => {
      cursor.style.transform = `translate(${e.clientX}px, ${e.clientY}px)`;
      cursor.classList.add('is-ready');
    };

    document.addEventListener('pointermove', move, { passive: true });

    document.addEventListener('mousedown', () => {
      cursor.style.transform += ' scale(0.8)';
    });

    document.addEventListener('mouseup', () => {
      cursor.style.transform = cursor.style.transform.replace(' scale(0.8)', '');
    });
  }

  setupCustomCursor();
</script>
