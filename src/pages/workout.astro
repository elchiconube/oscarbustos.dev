<script>
  function markWorkoutToday() {
    const root = document.getElementById('training-plan');
    if (!(root instanceof HTMLElement)) return;

    root.querySelectorAll('.week-day--today').forEach((el) => el.classList.remove('week-day--today'));
    root.querySelectorAll('.week-day[aria-current="date"]').forEach((el) => el.removeAttribute('aria-current'));
    root.querySelectorAll('.day-btn--today').forEach((el) => el.classList.remove('day-btn--today'));

    const jsDay = new Date().getDay();
    const todayCell = root.querySelector(`.week-day[data-weekday="${jsDay}"]`);
    todayCell?.classList.add('week-day--today');
    todayCell?.setAttribute('aria-current', 'date');

    root.querySelector(`.day-btn[data-cal-weekday="${jsDay}"]`)?.classList.add('day-btn--today');
  }

  function bindTrainingPlan() {
    const root = document.getElementById('training-plan');
    if (!(root instanceof HTMLElement)) return;

    if (root.dataset.workoutBound !== '1') {
      root.dataset.workoutBound = '1';

      root.querySelectorAll('.tab').forEach((node) => {
        node.addEventListener('click', () => {
          const t = node.getAttribute('data-tab');
          root.querySelectorAll('.tab').forEach((b) => {
            const active = b.getAttribute('data-tab') === t;
            b.classList.toggle('tab--active', active);
            b.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          root.querySelectorAll('.panel').forEach((p) => {
            p.classList.toggle('panel--active', p.id === `panel-${t}`);
          });
        });
      });

      root.querySelectorAll('.day-btn').forEach((node) => {
        node.addEventListener('click', () => {
          const idx = node.getAttribute('data-day');
          root.querySelectorAll('.day-btn').forEach((b) =>
            b.classList.toggle('day-btn--active', b.getAttribute('data-day') === idx)
          );
          root.querySelectorAll('.day-card').forEach((c) =>
            c.classList.toggle('day-card--active', c.getAttribute('data-day-panel') === idx)
          );
        });
      });
    }

    markWorkoutToday();
  }

  bindTrainingPlan();
  document.addEventListener('astro:page-load', bindTrainingPlan);
</script>
