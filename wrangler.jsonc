{
	"name": "portfolio",
  "compatibility_date": "2025-12-30",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist/client",
		"not_found_handling": "404-page",
		"html_handling": "force-trailing-slash"
	},
	"observability": {
    "enabled": true
  }
}